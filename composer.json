{
  "name": "covantis/waiver-system-full",
  "description": "Waiver management with DOCX import, PHP 8 + MySQL, Docker",
  "require": {
    "php": ">=8.2",
    "dompdf/dompdf": "^3.0",
    "phpoffice/phpword": "^1.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  }
}
